{
  "name": "frontend",
  "private": true,
  "scripts": {
    "prebuild": "npm run typegen",
    "build": "next build",
    "predev": "npm run typegen",
    "dev": "next dev --turbopack",
    "lint": "next lint",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "extract-schema": "sanity schema extract --enforce-required-fields",
    "typegen": "npm run extract-schema && sanity typegen generate"
  },
  "dependencies": {
    "@sanity/assist": "^5.0.4",
    "@sanity/client": "^7.9.0",
    "@sanity/image-url": "^1.1.0",
    "@sanity/uuid": "^3.0.2",
    "@sanity/vision": "^4.22.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "@vercel/speed-insights": "^1.2.0",
    "autoprefixer": "^10.4.21",
    "date-fns": "^4.1.0",
    "gsap": "^3.13.0",
    "lucide-react": "^0.553.0",
    "next": "15.5.7",
    "next-sanity": "^10.0.14",
    "pluralize-esm": "^9.0.5",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sanity": "^4.22.0",
    "sanity-plugin-asset-source-unsplash": "^4.0.1",
    "sonner": "^2.0.7",
    "styled-components": "^6.1.19",
    "tailwindcss": "^4.1.12"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "1.30.1",
    "@esbuild/linux-x64": "0.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.34.0",
    "eslint-config-next": "^15.5.0",
    "typescript": "5.9.2"
  }
}
